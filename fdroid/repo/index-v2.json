{"repo": {"name": {"en-US": "Loops unofficial F-Droid Repository"}, "description": {"en-US": "This is an unofficial Loops.Video F-Droid repository If you are unsure about this repo, please use the official Google Play Store app, or their GitHub https://github.com/joinloops/loops-expo"}, "icon": {"en-US": {"name": "/icons/loops.png", "sha256": "4d6a7822c4b31e5f1086b5a7aa882c49849ec6805499f6bbeb338726696efbe1", "size": 26267}}, "address": "https://apt-gdmc.ddns.net/repo", "mirrors": [{"isPrimary": true, "url": "https://apt-gdmc.ddns.net/repo"}, {"url": "https://raw.githubusercontent.com/Bibou1494/apt-gdmc/master/fdroid/repo"}], "webBaseUrl": "https://apt-gdmc.ddns.net/packages/", "timestamp": 1784557902000, "categories": {"Multimedia": {"name": {"en-US": "Multimedia"}}, "Social": {"name": {"en-US": "Social"}}}}, "packages": {"com.pixelfed.loops": {"metadata": {"added": 1782233483000, "categories": ["Social", "Multimedia"], "issueTracker": "https://github.com/joinloops/loops-expo/issues", "lastUpdated": 1782234399000, "sourceCode": "https://github.com/joinloops/loops-expo", "webSite": "https://joinloops.org", "featureGraphic": {"en-US": {"name": "/com.pixelfed.loops/en-US/featureGraphic_rs3HOotwOdmIHxDS9Wir1Ty6EIEcy9ZqVBiGAXB3JLU=.jpg", "sha256": "aecdc73a8b7039d9881f10d2f568abd53cba10811ccbd66a54188601707724b5", "size": 234724}}, "screenshots": {"phone": {"en-US": [{"name": "/com.pixelfed.loops/en-US/phoneScreenshots/screenshot1.png", "sha256": "07b4f19cac09d72939140403b41922094cc3697c53b2be5dfec89103574daf86", "size": 98543}, {"name": "/com.pixelfed.loops/en-US/phoneScreenshots/screenshot2.png", "sha256": "1b30f7f371d66c9c34bf09f632d59229a89fd7f32ebc5d73d1f9e1fa57cee1ee", "size": 27355}, {"name": "/com.pixelfed.loops/en-US/phoneScreenshots/screenshot3.png", "sha256": "104c645b61a67025f8a46453079ae547de21839114026ec318a075a79015f98b", "size": 207386}, {"name": "/com.pixelfed.loops/en-US/phoneScreenshots/screenshot4.png", "sha256": "f481d19346e5d44f06610df3606db8e8720d39bb5245bf4310969e11f034460b", "size": 22959}, {"name": "/com.pixelfed.loops/en-US/phoneScreenshots/screenshot5.png", "sha256": "9bec8cb34f3675bede1f2056fff4891631795fa50169fac04ebb4ddd385bd65b", "size": 47064}]}}, "authorName": "Daniel Supernault", "name": {"en-US": "Loops"}, "summary": {"en-US": "The federated short video sharing platform app."}, "description": {"en-US": "Loops is short-form video for a more open internet. Discover and share quick, creative videos in a feed that feels instantly familiar — minus the ads, the tracking, and the algorithm built to keep you hooked.\n\nLoops is part of the fediverse, a network of independent, connected platforms built on open standards. Your account isn't locked inside one company's walls. You own your content, you control your experience, and you connect with people across the wider social web — built on ActivityPub, the same open protocol behind Mastodon and Pixelfed.\n\nWHAT YOU CAN DO\n🎬 Discover short videos in an endless, swipeable feed\n📤 Create and share your own videos in seconds\n🎵 Find and reuse sounds from across the community\n💬 Comment, follow, and connect with the creators you love\n🔍 Explore what's trending and find your people\n🌐 Reach the whole fediverse, not just one app\n\nWHY LOOPS IS DIFFERENT\n✊ No ads. No tracking. No data harvesting.\n🧠 No manipulative algorithm designed to keep you scrolling\n🔓 Fully open source — anyone can inspect it, contribute, or self-host\n💚 Community-funded, with no venture capital and no corporate owners\n📦 Your content is yours, built on open standards you can take with you\n\nLoops is built by a small, independent team that believes social media should serve people, not shareholders. Join us and help build a more open internet — one loop at a time.\n"}, "icon": {"en-US": {"name": "/com.pixelfed.loops/en-US/icon_Q024BD2knyJ30A_AUaqsdIPDAnVG9k9ruNngy9OZOXk=.png", "sha256": "434db8043da49f2277d00fc051aaac7483c3027546f64f6bb8d9e0cbd3993979", "size": 27066}}, "preferredSig