{"repo": {"timestamp": 1784557902000, "version": 20002, "name": "Loops unofficial F-Droid Repository", "icon": "loops.png", "address": "https://apt-gdmc.ddns.net/repo", "webBaseUrl": "https://apt-gdmc.ddns.net/packages/", "description": "This is an unofficial Loops.Video F-Droid repository If you are unsure about this repo, please use the official Google Play Store app, or their GitHub https://github.com/joinloops/loops-expo", "mirrors": ["https://raw.githubusercontent.com/Bibou1494/apt-gdmc/master/fdroid/repo"]}, "requests": {"install": [], "uninstall": []}, "apps": [{"authorName": "Daniel Supernault", "categories": ["Social", "Multimedia"], "suggestedVersionCode": "1024", "issueTracker": "https://github.com/joinloops/loops-expo/issues", "license": "Unknown", "name": "Loops", "sourceCode": "https://github.com/joinloops/loops-expo", "summary": "The federated short video sharing platform app.", "webSite": "https://joinloops.org", "added": 1782233483000, "packageName": "com.pixelfed.loops", "lastUpdated": 1782234399000, "localized": {"en-US": {"description": "Loops is short-form video for a more open internet. Discover and share quick, creative videos in a feed that feels instantly familiar \u2014 minus the ads, the tracking, and the algorithm built to keep you hooked.\n\nLoops is part of the fediverse, a network of independent, connected platforms built on open standards. Your account isn't locked inside one company's walls. You own your content, you control your experience, and you connect with people across the wider social web \u2014 built on ActivityPub, the same open protocol behind Mastodon and Pixelfed.\n\nWHAT YOU CAN DO\n\ud83c\udfac Discover short videos in an endless, swipeable feed\n\ud83d\udce4 Create and share your own videos in seconds\n\ud83c\udfb5 Find and reuse sounds from across the community\n\ud83d\udcac Comment, follow, and connect with the creators you love\n\ud83d\udd0d Explore what's trending and find your people\n\ud83c\udf10 Reach the whole fediverse, not just one app\n\nWHY LOOPS IS DIFFERENT\n\u270a No ads. No tracking. No data harvesting.\n\ud83e\udde0 No manipulative algorithm designed to keep you scrolling\n\ud83d\udd13 Fully open source \u2014 anyone can inspect it, contribute, or self-host\n\ud83d\udc9a Community-funded, with no venture capital and no corporate owners\n\ud83d\udce6 Your content is yours, built on open standards you can take with you\n\nLoops is built by a small, independent team that believes social media should serve people, not shareholders. Join us and help build a more open internet \u2014 one loop at a time.\n", "featureGraphic": "featureGraphic_rs3HOotwOdmIHxDS9Wir1Ty6EIEcy9ZqVBiGAXB3JLU=.jpg", "icon": "icon_Q024BD2knyJ30A_AUaqsdIPDAnVG9k9ruNngy9OZOXk=.png", "phoneScreenshots": ["screenshot1.png", "screenshot2.png", "screenshot3.png", "screenshot4.png", "screenshot5.png"]}}}], "packages": {"com.pixelfed.loops": [{"added": 1782233483000, "apkName": "com.pixelfed.loops_1024.apk", "hash": "1ea91125f1b81d7a90d5b99f2da1d373a61b89f17b23aa4508983824dba1ff81", "hashType": "sha256", "minSdkVersion": 24, "nativecode": ["arm64-v8a", "armeabi-v7a"], "packageName": "com.pixelfed.loops", "sig": "b4f61658abebe3888feede7bb9165895", "signer": "be7c0a65e2b48789a7ff0dd635cf653f161194b2ff00786f1dfbb8bc3eab0ab8", "size": 97452307, "targetSdkVersion": 36, "uses-permission": [["android.permission.ACCESS_MEDIA_LOCATION", null], ["android.permission.CAMERA", null], ["android.permission.INTERNET", null], ["android.permission.READ_EXTERNAL_STORAGE", 32], ["android.permission.READ_MEDIA_AUDIO", null], ["android.permission.READ_MEDIA_IMAGES", null], ["android.permission.READ_MEDIA_VISUAL_USER_SELECTED", null], ["android.permission.RECORD_AUDIO", null], ["android.permission.SYSTEM_ALERT_WINDOW", null], ["android.permission.VIBRATE", null], ["android.permission.WRITE_EXTERNAL_STORAGE", 32], ["android.permission.ACCESS_NETWORK_STATE", null], ["android.permission.RECEIVE_BOOT_COMPLETED", null], ["android